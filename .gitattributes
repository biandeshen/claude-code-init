# Shell scripts must always use LF line endings
*.sh text eol=lf

# PowerShell scripts use CRLF
*.ps1 text eol=crlf

# Python files use LF
*.py text eol=lf

# Markdown files use LF
*.md text eol=lf

# YAML files use LF
*.yaml text eol=lf
*.yml text eol=lf

# JSON files use LF
*.json text eol=lf

# JavaScript files use LF
*.js text eol=lf
